{
	"name": "@spencerbeggs/vitest-bats",
	"version": "0.0.0",
	"private": true,
	"description": "Test bash scripts with kcov coverage directly in Vitest",
	"keywords": ["vitest", "bats", "bash", "shell", "testing", "kcov", "coverage"],
	"homepage": "https://github.com/spencerbeggs/vitest-bats#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/vitest-bats/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-bats.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --log-prefix=none --output-logs=full --no-color",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:local": "pnpm run build && vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@savvy-web/silk": "^2.0.0",
		"@vitest-agent/plugin": "^1.1.4",
		"vitest-bats": "workspace:*"
	},
	"packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.34.1",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.3.0",
				"onFail": "ignore"
			}
		]
	}
}
