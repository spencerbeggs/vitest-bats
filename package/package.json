{
	"name": "vitest-bats",
	"version": "0.0.1",
	"private": true,
	"description": "Test bash scripts with kcov coverage directly in Vitest",
	"keywords": ["vitest", "bats", "bash", "shell", "testing", "kcov", "coverage", "vitest-plugin"],
	"homepage": "https://github.com/spencerbeggs/vitest-bats#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/vitest-bats/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-bats.git",
		"directory": "package"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./runtime": "./src/runtime.ts",
		"./setup": "./src/setup.ts"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "node savvy.build.ts --target dev",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@standard-schema/spec": "^1.1.0",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"fast-xml-parser": "^5.8.0",
		"minimatch": "^10.2.5"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.9.2",
		"@types/node": "catalog:silk",
		"tsx": "catalog:silk",
		"typescript": "catalog:silk",
		"vite": "^8.0.10"
	},
	"peerDependencies": {
		"vitest": ">=4.1.0"
	},
	"peerDependenciesMeta": {
		"vitest": {
			"optional": false
		}
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/vitest-bats"
		}
	}
}
